<Window x:Class="HabboCustomLauncher.LoadingWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HabboCustomLauncher"
        x:Name="Window"
        mc:Ignorable="d" Width="602" Height="212" CanResize="False" SystemDecorations="BorderOnly" Opacity="1"
        Title="HFA Launcher"
        WindowStartupLocation="CenterScreen" Background="{StaticResource HfaBlackBrush}" FontFamily="{StaticResource HfaBodyFont}" Icon="/Assets/HabboCustomLauncherIcon.ico">
	<Grid>
		<Panel>
			<Panel Background="{StaticResource HfaWindowBackdrop}"/>
			<Panel Background="{StaticResource HfaGreenGlow}"/>
		</Panel>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="32"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>
			<Label Name="TitleBarLabel" Grid.Row="0" Background="{StaticResource HfaTitleBarBrush}" Foreground="{StaticResource HfaGreenBrush}" Content="    HFA · LAUNCHER" FontFamily="{StaticResource HfaTitleFont}" FontSize="19" VerticalContentAlignment="Center"/>
			<Border Grid.Row="0" VerticalAlignment="Bottom" Height="2" Background="{StaticResource HfaGreenBrush}"/>
			<local:CustomButton x:Name="CloseButton" IsFocusable="False" Grid.Row="0" Foreground="White" HorizontalAlignment="Right" Text="   X   " BackColor="{StaticResource HfaRedColor}"/>
			<Border Grid.Row="1" BorderThickness="1,0,1,1" BorderBrush="{StaticResource HfaBorderBrightBrush}">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="*"/>
						<RowDefinition Height="1"/>
						<RowDefinition Height="60"/>
					</Grid.RowDefinitions>
					<TextBlock x:Name="StatusLabel" Grid.Row="0" Margin="15" Text="Unknown status!" TextTrimming="CharacterEllipsis" Foreground="{StaticResource HfaTextBrush}" FontSize="30" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
					<Grid Grid.Row="1" Background="{StaticResource HfaGreenBrush}" Opacity="0.25" Margin="10,0,10,0"/>
					<local:CustomButton x:Name="MainMenuButton" Grid.Row="2" Text="Return to main menu" BackColor="{StaticResource HfaGreenDarkColor}" Foreground="#062012" Margin="10"/>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>
